        function loadConfig() {
            const saved = localStorage.getItem(CONFIG_STORAGE_KEY);
            if (saved) {
                try {
                    const parsed = JSON.parse(saved);
                    // Merge with defaults
                    CONFIG = { ...CONFIG, ...parsed };
                } catch (e) {
                    console.error("Error loading config", e);
                }
            }
        }

        function saveConfig() {
            localStorage.setItem(CONFIG_STORAGE_KEY, JSON.stringify(CONFIG));
