        async function handleSelection(index) {
            if (gamePhase !== 'POKEMON') return;

            // Se bloccato, ignora
            if (document.body.dataset.processing === "true") return;

            const pokemon = onScreenCandidates[index];
            if (!pokemon || team.length >= CONFIG.teamSize) return;

            // 1. Locks UI
            document.body.dataset.processing = "true";

            // 2. Visual Feedback (Azzurrino)
            const card = grid.children[index];
            if (card) {
                card.style.background = 'linear-gradient(180deg, #a5f3fc 0%, #e0f2fe 100%)';
                card.style.transform = 'scale(0.95)';
                card.onclick = null;
            }

            team.push(pokemon);
            selectedPokemonIds.add(pokemon.id);
            updateTeamDisplay();


            // 3. Start Timer (1.5s Min Delay)
            const delayPromise = new Promise(resolve => setTimeout(resolve, 1500));

            // check if team complete
            if (team.length >= CONFIG.teamSize) {
                await delayPromise;
                document.body.dataset.processing = "false";
                startMoveSelection();
                return;
            }

            // 4. Background Fetch (Next 3)
            reserveBuffer = [];
            await fillReserve(3);

            // Preload images for next candidates
            const nextCandidates = reserveBuffer.slice(0, 3);
            const imagePromises = nextCandidates.map(p => preloadImage(p.sprite));

            // 5. Wait for Delay AND Images
            await Promise.all([delayPromise, ...imagePromises]);

            // 6. Update UI (Replace All)
            // Manual refresh to avoid double buffer clear
            onScreenCandidates[0] = reserveBuffer.shift();
            onScreenCandidates[1] = reserveBuffer.shift();
            onScreenCandidates[2] = reserveBuffer.shift();
            renderGrid();
            fillReserve(6); // Refill future

            saveSession();

            document.body.dataset.processing = "false";
        }

