            CONFIG.minTotalEVs = parseInt(document.getElementById('settingMinEVs').value) || 510;
            CONFIG.maxTotalEVs = parseInt(document.getElementById('settingMaxEVs').value) || 510;

            saveConfig(); // Save to persistent storage
            updateCacheKey();

            // Check cache again with new key
            const cachedData = localStorage.getItem(CACHE_KEY);

            // Chiudi modal forzatamente
            modal.classList.remove('active');
            modal.dataset.force = "false";

