            gridDiv.innerHTML = `
            <div class="loading" style="max-width:600px; margin:0 auto;">
                <h2 style="color:#2c3e50; margin-bottom:15px;">Costruzione Database Locale</h2>

                <div style="display:flex; flex-wrap:wrap; gap:10px; justify-content:center; margin-bottom:20px;">
                    <span style="${badgeStyle}">Gen: 1-${CONFIG.maxGeneration}</span>
                    <span style="${badgeStyle}">Min BST: ${CONFIG.minBaseStats}</span>
                    <span style="${badgeStyle}">Team: ${CONFIG.teamSize}</span>
                    <span style="${badgeStyle}">Fully Evolved: ${CONFIG.onlyFullyEvolved ? '✅' : '❌'}</span>
                    <span style="${badgeStyle}">Leggendari: ${CONFIG.allowLegendaries ? '✅' : '❌'}</span>
                </div>

                <div style="text-align:left; margin-bottom:5px; color:#555; font-weight:bold;" id="phaseLabel">Avvio inizializzazione...</div>

                <div style="width:100%; background:#eee; height:20px; border-radius:10px; overflow:hidden; border:1px solid #ccc; margin-bottom:10px;">
                    <div id="progressBar" style="width:0%; height:100%; background:linear-gradient(90deg, #3498db, #2ecc71); transition:width 0.1s;"></div>
                </div>

                <div style="display:flex; justify-content:space-between; font-size:0.9em; color:#666;">
                    <span id="progressCount">0/0</span>
                    <span id="progressPercent">0%</span>
                </div>

                <p style="font-size:0.8em; color:#888; margin-top:15px;">
                    🚀 Modalità Turbo attiva
                </p>
            </div>
        `;

            // Riferimenti DOM per aggiornamenti rapidi
            const elPhase = document.getElementById('phaseLabel');
            const elBar = document.getElementById('progressBar');
            const elCount = document.getElementById('progressCount');
            const elPercent = document.getElementById('progressPercent');

            // Funzione helper per aggiornare la barra
            const updateUI = (current, total, phaseName) => {
                const pct = Math.round((current / total) * 100);
                elBar.style.width = `${pct}%`;
                elCount.textContent = `${current}/${total}`;
                elPercent.textContent = `${pct}%`;
                if (phaseName) elPhase.textContent = phaseName;
            };

            // CONFIGURAZIONE CONCORRENZA
            const CONCURRENCY_LIMIT = 60; // Aumentato leggermente per localhost

            try {
                /* ----------------------------------------------------------------
                   FASE 1: Ottenere tutte le Specie
                   ---------------------------------------------------------------- */
                updateUI(0, 100, "Fase 1/4: Recupero elenco Generazioni...");

                let genPromises = [];
                for (let i = 1; i <= CONFIG.maxGeneration; i++) {
                    genPromises.push(fetch(`${API_BASE}/api/v2/generation/${i}/`).then(r => r.json()));
                }

                const genResults = await Promise.all(genPromises);
                let allSpeciesUrls = [];
                genResults.forEach(g => {
                    allSpeciesUrls.push(...g.pokemon_species.map(s => s.url));
                });

                /* ----------------------------------------------------------------
                   FASE 2: Scaricare Dettagli Specie
                   ---------------------------------------------------------------- */
                let processedCount = 0;
                const totalSpecies = allSpeciesUrls.length;
                updateUI(0, totalSpecies, `Fase 2/4: Analisi Specie (Filtro base)...`);

                const allSpeciesData = await runWithConcurrency(allSpeciesUrls, async (url) => {
                    const res = await fetch(url);
                    const data = await res.json();

                    // Aggiorna UI
                    processedCount++;
                    if (processedCount % 5 === 0) updateUI(processedCount, totalSpecies); // Aggiorna ogni 5 per performance

                    return data;
                }, CONCURRENCY_LIMIT);

                // Update finale fase 2
                updateUI(totalSpecies, totalSpecies);


                // Filtri in memoria (Leggendari)
                let candidateSpecies = [];
                let uniqueChainUrls = new Set();

                allSpeciesData.forEach(s => {
                    if (!CONFIG.allowLegendaries && (s.is_legendary || s.is_mythical)) return;
                    candidateSpecies.push(s);
                    uniqueChainUrls.add(s.evolution_chain.url);
                });

                /* ----------------------------------------------------------------
                   FASE 3: Scaricare Catene Evolutive
                   ---------------------------------------------------------------- */
                const totalChains = uniqueChainUrls.size;
                processedCount = 0;
                updateUI(0, totalChains, `Fase 3/4: Analisi Evoluzioni (${totalChains} famiglie)...`);

                const chainsData = await runWithConcurrency(Array.from(uniqueChainUrls), async (url) => {
                    const res = await fetch(url);
                    const data = await res.json();

                    processedCount++;
                    if (processedCount % 2 === 0) updateUI(processedCount, totalChains);

                    return data;
                }, CONCURRENCY_LIMIT);

                // Mappa Chain
                const chainMap = {};
                chainsData.forEach(c => { chainMap[c.id] = c.chain; });

                // Filtro Fully Evolved in memoria
                let survivorsAfterEvo = [];
                for (const s of candidateSpecies) {
                    if (CONFIG.onlyFullyEvolved) {
                        const chainUrlParts = s.evolution_chain.url.split('/');
                        const chainId = chainUrlParts[chainUrlParts.length - 2];
                        const chainNode = chainMap[chainId];
                        if (chainNode && canEvolve(s.name, chainNode)) continue;
                    }
                    survivorsAfterEvo.push(s);
                }

                /* ----------------------------------------------------------------
                   FASE 4: Stats Check
                   ---------------------------------------------------------------- */
                const totalSurvivors = survivorsAfterEvo.length;
                processedCount = 0;
                updateUI(0, totalSurvivors, `Fase 4/4: Verifica Stats (> ${CONFIG.minBaseStats} BST)...`);

                const finalPokemonIds = [];

                await runWithConcurrency(survivorsAfterEvo, async (species) => {
                    try {
                        const defaultVariety = species.varieties.find(v => v.is_default);

                        if (defaultVariety) {
                            const res = await fetch(defaultVariety.pokemon.url);
                            const pkm = await res.json();
                            const bst = pkm.stats.reduce((acc, s) => acc + s.base_stat, 0);

                            if (bst >= CONFIG.minBaseStats) {
                                finalPokemonIds.push(pkm.id);
                            }
                        }
                    } catch (e) {
                        console.error("Errore fetch stats", species.name);
                    } finally {
                        processedCount++;
                        if (processedCount % 2 === 0) updateUI(processedCount, totalSurvivors);
                    }
                }, CONCURRENCY_LIMIT);

                /* ----------------------------------------------------------------
                   CONCLUSIONE
                   ---------------------------------------------------------------- */
                validPokemonList = finalPokemonIds.sort((a, b) => a - b);
                localStorage.setItem(CACHE_KEY, JSON.stringify(validPokemonList));

                elPhase.innerHTML = `<span style="color:green">✅ Completato! Trovati ${validPokemonList.length} Pokémon.</span>`;
                elBar.style.background = "#27ae60"; // Verde fisso

                // Breve pausa per far vedere il 100% all'utente
                await new Promise(r => setTimeout(r, 800));

                if (validPokemonList.length === 0) {
                    gridDiv.innerHTML = `<div class="loading" style="color:red">⚠️ Nessun Pokémon trovato con questi criteri.<br>Prova ad abbassare le Statistiche minime o includere i non evoluti.</div>`;
                } else {
                    await startGame();
                }

            } catch (error) {
                console.error("Errore critico build:", error);
                gridDiv.innerHTML = `<div class="loading" style="color:red">Errore critico: ${error.message}</div>`;
            }
        }

        /* ----------------------------------------------------------------
HELPER CONCORRENZA (Versione Corretta e Unica)
Esegue una lista di items in parallelo con un limite massimo
di richieste simultanee.
---------------------------------------------------------------- */
        async function runWithConcurrency(array, asyncFn, concurrency) {
            const results = new Array(array.length);
            let index = 0;

            // Funzione worker che consuma la coda
            const worker = async () => {
                while (index < array.length) {
                    const i = index++; // Prende il prossimo indice e incrementa
                    try {
                        results[i] = await asyncFn(array[i]);
                    } catch (err) {
                        console.error("Errore gestito in runWithConcurrency:", err);
                        results[i] = null;
                    }
                }
            };

            // Avvia n workers simultanei
            const workers = [];
            for (let i = 0; i < concurrency; i++) {
                workers.push(worker());
            }

            // Aspetta che tutti finiscano
            await Promise.all(workers);

            // Ritorna i risultati puliti da eventuali null (errori)
            return results.filter(r => r !== null);
        }

        // Check if Pokemon is fully evolved relative to the selected generation.
        function canEvolve(speciesName, chainNode) {
            // 1. Find the node for this species
            const myNode = findNode(speciesName, chainNode);
            if (!myNode) return false;

            // 2. Check direct evolutions
            if (myNode.evolves_to.length === 0) return false; // Absolutely no evolutions

            // 3. If there are evolutions, check if ANY are valid in the current MAX Generation
            // If at least one evolution is valid (ID <= Limit), then it CAN evolve -> Not Fully Evolved
            const maxId = GEN_LIMITS[CONFIG.maxGeneration];

            for (const evo of myNode.evolves_to) {
                const url = evo.species.url; // e.g., .../pokemon-species/464/
                const parts = url.split('/');
                const id = parseInt(parts[parts.length - 2]);

                if (id <= maxId) {
                    return true; // Found an evolution within the generation limit!
                }
            }

            // All found evolutions are from future generations
            return false;
        }

        function findNode(name, node) {
            if (node.species.name === name) return node;
            for (const child of node.evolves_to) {
                const res = findNode(name, child);
                if (res) return res;
            }
            return null;
        }

        // Sostituiamo la chiamata su nel loop:
        // if (!isFullyEvolvedCheck(species.name, chainData.chain)) return; Use this logic inside build.

        /* -------------------------------------------------------------
           GAME LOGIC (BUFFER & UI)
           ------------------------------------------------------------- */

        const SESSION_KEY = 'pokemon_team_session';

        async function startGame() {
            document.body.dataset.processing = "false";
            grid.innerHTML = '<div class="loading">Inizializzazione sessione...</div>';

            loadSession();
            updateTeamDisplay();

            if (gamePhase === 'COMPLETED') {
                finishGame();
                return;
            }

            if (validPokemonList.length === 0) {
                grid.innerHTML = '<div class="loading" style="color:red">Nessun pokemon trovato!</div>';
                return;
            }

            // LOGICA DI RIPRESA
            if (team.length >= CONFIG.teamSize) {
                // Se il team è pieno, controlliamo in che fase siamo
                if (gamePhase === 'MOVES') {
                    await startMoveSelection(true);
                } else if (gamePhase === 'NATURES') {
                    // Start Nature Phase
                    startNatureSelection(true);
                } else if (gamePhase === 'EVS') {
                    // Start EV Phase
                    startEvSelection(true);
                } else if (gamePhase === 'ITEMS') {
                    // Start Item Phase
                    startItemSelection(true);
                } else {
                    // Finito tutto
                    finishGame();
                }
            } else {
                // Fase Pokemon
                if (!onScreenCandidates || !onScreenCandidates[0]) {
                    candidateBuffer = [];
                    onScreenCandidates = [null, null, null];
                    reserveBuffer = [];
                    await refreshCandidates();
                } else {
                    renderGrid();
                    if (reserveBuffer.length < 6) fillReserve(6);
                }
            }
        }

        function saveSession() {
            const data = {
                team: team,
                selectedIds: Array.from(selectedPokemonIds),
                gamePhase: gamePhase,
                currentPokeIndex: currentPokeIndex,
                currentMoveOptions: currentMoveOptions,
                natureOptions: natureOptions, // <--- AGGIUNTO
                natureOptions: natureOptions,
                evOptions: evOptions,
                itemOptions: itemOptions, // <--- ITEM OPTIONS ADDED
                onScreenCandidates: onScreenCandidates,
                reserveBuffer: reserveBuffer,
                moveBuffer: moveBuffer
            };
            localStorage.setItem(SESSION_KEY, JSON.stringify(data));
        }

        function loadSession() {
            const json = localStorage.getItem(SESSION_KEY);
            if (json) {
                try {
                    const data = JSON.parse(json);
                    team = data.team || [];
                    selectedPokemonIds = new Set(data.selectedIds || []);
                    gamePhase = data.gamePhase || 'POKEMON';
                    currentPokeIndex = data.currentPokeIndex || 0;
                    currentMoveOptions = data.currentMoveOptions || [];
                    natureOptions = data.natureOptions || [];
                    natureOptions = data.natureOptions || [];
                    evOptions = data.evOptions || [];
                    itemOptions = data.itemOptions || []; // <--- ITEM OPTIONS ADDED
                    onScreenCandidates = data.onScreenCandidates || [null, null, null];
                    reserveBuffer = data.reserveBuffer || [];
                    moveBuffer = data.moveBuffer || [];
                } catch (e) { console.error(e); }
            }
        }

        function clearSession() {
            localStorage.removeItem(SESSION_KEY);
        }

        async function refreshCandidates() {
            // Svuota riserva
            reserveBuffer = [];

            // 3 Nuovi
            await fillReserve(3);

            onScreenCandidates[0] = reserveBuffer.shift();
            onScreenCandidates[1] = reserveBuffer.shift();
            onScreenCandidates[2] = reserveBuffer.shift();

            renderGrid();

            // Prepara futuri
            fillReserve(6);
        }

        function renderGrid() {
            grid.innerHTML = '';
            onScreenCandidates.forEach((p, index) => {
                const card = document.createElement('div');
                card.className = 'pokemon-card';
                if (p) {
                    fillCardContent(card, p);
                    card.onclick = () => handleSelection(index);

                    // --- NUOVO: Aggiungiamo il click col tasto destro ---
                    card.oncontextmenu = (event) => {
                        event.preventDefault(); // Evita che si apra il classico menù di Chrome/Windows
                        openStatsModal(p);
                    };

                } else {
                    card.innerHTML = '<div class="loading">...</div>';
                }
                grid.appendChild(card);
            });
        }

        async function fillReserve(targetSize) {
            const needed = targetSize - reserveBuffer.length;
            if (needed <= 0) return;

            const promises = [];
            for (let i = 0; i < needed; i++) {
                promises.push(fetchRandomPokemonData());
            }

            // Aspettiamo tutti e filtriamo i null
            const results = await Promise.all(promises);
            const validResults = results.filter(p => p !== null);
            reserveBuffer.push(...validResults);
        }

        function randomIndex(max) {
            const array = new Uint32Array(1);
            crypto.getRandomValues(array);
            return array[0] % max;
        }

        async function fetchRandomPokemonData() {
            // 1. Filtra quelli già selezionati O già nella riserva O già a schermo
            const usedIds = new Set([...selectedPokemonIds]);
            onScreenCandidates.forEach(p => p && usedIds.add(p.id));
            reserveBuffer.forEach(p => p && usedIds.add(p.id));

            const available = validPokemonList.filter(id => !usedIds.has(id));

            if (available.length === 0) return null;

            const randomId = available[randomIndex(available.length)];

            try {
                const res = await fetch(`${API_BASE}/api/v2/pokemon/${randomId}`);
                const data = await res.json();

                // --- LOGICA SELEZIONE ABILITÀ CORRETTA ---

                // Fetch parallelo dei dettagli di tutte le abilità del Pokémon
                const abilityPromises = data.abilities.map(async (slot) => {

                    // FILTRO 1: Abilità Nascoste (Hidden)
                    // Le Hidden Abilities sono state introdotte nella Gen 5.
                    // Se la config è < 5, ignoriamo qualsiasi abilità marcata come hidden.
                    if (CONFIG.maxGeneration < 5 && slot.is_hidden) {
                        return null;
                    }

                    try {
                        const aRes = await fetch(slot.ability.url);
                        const aData = await aRes.json();

                        // FILTRO 2: Generazione di introduzione dell'abilità
                        // Controlliamo quando l'abilità è stata creata.
                        const genUrlParts = aData.generation.url.split('/');
                        const genId = parseInt(genUrlParts[genUrlParts.length - 2]);

                        // Se l'abilità è nata in una generazione successiva a quella scelta, scartala.
                        if (genId <= CONFIG.maxGeneration) {
                            // Trova nome italiano
                            let name = aData.names.find(n => n.language.name === 'it')?.name || aData.name;
                            return { name: name, slug: aData.name };
                        }
                    } catch (e) { console.error("Error fetching ability", e); }

                    return null;
                });

                // Risolvi tutte le promise e filtra i null
                const abilitiesResults = await Promise.all(abilityPromises);
                const validAbilities = abilitiesResults.filter(a => a !== null);

                // Calcolo BST (Base Stat Total) e statistiche singole
                const bst = data.stats.reduce((acc, s) => acc + s.base_stat, 0);
                const individualStats = {
                    hp: data.stats[0].base_stat,
                    atk: data.stats[1].base_stat,
                    def: data.stats[2].base_stat,
                    spa: data.stats[3].base_stat,
                    spd: data.stats[4].base_stat,
                    spe: data.stats[5].base_stat
                };

                // Se non ci sono abilità valide (es. Gen 1), mettiamo un placeholder
                if (validAbilities.length === 0) {
                    validAbilities.push({ name: "-", slug: "-" });
                }

                return {
                    id: data.id,
                    name: data.name,
                    sprite: data.sprites.front_default,
                    types: data.types.map(t => t.type.name),
                    moves: data.moves,
                    abilities: validAbilities,
                    currentAbilityIndex: 0,
                    bst: bst,
                    individualStats: individualStats // <-- Salviamo le statistiche singole qui
                };
            } catch (e) {
                console.error(e);
                return null;
            }
        }

        // Logic Mosse
        let gamePhase = 'POKEMON'; // 'POKEMON' | 'MOVES'
        let currentPokeIndex = 0; // Index of team member getting moves
        let currentMoveOptions = []; // Mosse a schermo

        async function startMoveSelection(resume = false) {
            gamePhase = 'MOVES';

            if (!resume) {
                currentPokeIndex = 0;
            } else {
                // Find first pokemon with < 4 moves
                // Fallback scan just in case saved index is wrong or out of sync
                let foundIndex = -1;
                for (let i = 0; i < team.length; i++) {
                    if (!team[i].selectedMoves || team[i].selectedMoves.length < 4) {
                        foundIndex = i;
                        break;
                    }
                }

                if (foundIndex !== -1) {
                    currentPokeIndex = foundIndex;
                } else {
                    // All full?
                    currentPokeIndex = team.length;
                }
            }

            // UI Update
            document.querySelector('.title h1').textContent = "Scegli una Mossa";
            document.querySelector('.reset-btn').style.display = 'block'; // Keep reset available

            // USE MAIN GRID
            grid.innerHTML = '<div class="loading">Inizializzazione Draft Mosse...</div>';

            // Init Moves for team
            team.forEach(p => {
                if (!p.selectedMoves) p.selectedMoves = [];
            });

            updateTeamDisplay();

            // Resume logic: Use existing buffer/options?
            // If resume AND we have currentMoveOptions, use them
            if (resume && currentMoveOptions.length > 0) {
                // Ensure Title is correct on resume
                const currentPokemon = team[currentPokeIndex];
                const moveNum = currentPokemon.selectedMoves.length + 1;
                document.querySelector('.title h1').textContent = `Scegli Mossa ${moveNum}/4 per ${currentPokemon.name}`;

                renderMoveOptions(currentMoveOptions);
                return;
            }

            // Initial Buffer Fill (6 items = 2 turns)
            moveBuffer = [];
            await fillMoveBuffer(6);

            showMoveOptions();
        }

        async function fillMoveBuffer(count) {
            const currentPokemon = team[currentPokeIndex];
            if (!currentPokemon) return;

            // Get random moves
            const newMoves = await fetchRandomMovesFor(currentPokemon, count);
            moveBuffer.push(...newMoves);
        }



        function showMoveOptions() {
            // Check if done with MOVES
            if (currentPokeIndex >= team.length) {
                // Salva stato transitorio
                currentMoveOptions = [];
                saveSession();

                // AVVIA FASE NATURE
                startNatureSelection();
                return;
            }

            // ... (il resto della funzione showMoveOptions rimane uguale) ...
            const currentPokemon = team[currentPokeIndex];
            if (moveBuffer.length < 3) {
                grid.innerHTML = '<div class="loading">Caricamento buffer mosse...</div>';
                fillMoveBuffer(6).then(() => showMoveOptions());
                return;
            }
            const movesToShow = [moveBuffer.shift(), moveBuffer.shift(), moveBuffer.shift()];
            currentMoveOptions = movesToShow;
            saveSession();
            renderMoveOptions(movesToShow);
            const moveNum = currentPokemon.selectedMoves.length + 1;
            document.querySelector('.title h1').textContent = `Scegli Mossa ${moveNum}/4 per ${currentPokemon.name}`;
            updateTeamDisplay();
        }

        async function selectMove(move) {
            // Lock?
            if (document.body.dataset.processing === "true") return;

            const currentPokemon = team[currentPokeIndex];
            currentPokemon.selectedMoves.push(move);
            saveSession();
            updateTeamDisplay();

            // Check progress
            if (currentPokemon.selectedMoves.length >= 4) {
                currentPokeIndex++;
                // We might need to refresh buffer for NEXT pokemon if index changed?
                if (CONFIG.legalMovesOnly && currentPokeIndex < team.length) {
                    moveBuffer = []; // Flush buffer for new pokemon in Legal Mode
                    grid.innerHTML = '<div class="loading">Cambio Pokemon...</div>';
                    await fillMoveBuffer(6);
                }
            }

            // Background refill if team not done
            if (currentPokeIndex < team.length) {
                fillMoveBuffer(3);
            }

            // Immediate Show
            showMoveOptions();
        }

        // Global cache for Chaos Mode
        let allChaosMoves = null;

        async function ensurePokemonMoves(pokemon) {
            if (!pokemon.moves || pokemon.moves.length === 0) {
                // Fetch full data again
                try {
                    const res = await fetch(`${API_BASE}/api/v2/pokemon/${pokemon.id}`);
                    const data = await res.json();
                    pokemon.moves = data.moves;
                    pokemon.types = data.types.map(t => t.type.name);
                } catch (e) {
                    console.error("Failed to recover moves for", pokemon.name);
                    pokemon.moves = [];
                }
            }
        }

        async function getAllChaosMoves() {
            if (allChaosMoves) return allChaosMoves;

            // Build list of ALL moves from Gen 1 to Config.MaxGen
            let urls = [];
            for (let i = 1; i <= CONFIG.maxGeneration; i++) {
                try {
                    const res = await fetch(`${API_BASE}/api/v2/generation/${i}/`);
                    const data = await res.json();
                    urls.push(...data.moves.map(m => m.url));
                } catch (e) {
                    console.error("Error fetching gen moves", i, e);
                }
            }
            allChaosMoves = urls;
            return allChaosMoves;
        }

        async function fetchRandomMovesFor(pokemon, count = 3) {
            // Ensure pokemon has 'moves' property if we are in Legal Mode
            if (CONFIG.legalMovesOnly) {
                await ensurePokemonMoves(pokemon);
            }

            // GLOBAL UNIQUENESS: Check moves from ALL team members
            const usedSlugs = new Set();
            const bannedSubstrings = [ , 'z-', 'max-']; // personalizza qui le sottostringhe da escludere

            team.forEach(p => {
                if (!p.selectedMoves) return;
                p.selectedMoves.forEach(m => {
                    const slug = (m.originalName || m.name || '').toLowerCase();
                    // salta le mosse che contengono una sottostringa vietata
                    if (bannedSubstrings.some(sub => slug.includes(sub))) return;
                    usedSlugs.add(m.originalName || m.name);
                });
            });

            // OPTIMIZED LEARNSET VALIDATION
            // Create set of allowed version groups based on Max Gen
            const allowedGroups = new Set();
            for (let g = 1; g <= CONFIG.maxGeneration; g++) {
                if (GEN_VERSION_GROUPS[g]) {
                    GEN_VERSION_GROUPS[g].forEach(grp => allowedGroups.add(grp));
                }
            }

            let poolUrls = [];

            if (CONFIG.legalMovesOnly) {
                // LEGAL MODE: Filter locally by Learnset & Global Uniqueness
                poolUrls = pokemon.moves
                    .filter(m => {
                        // 1. Check Global Uniqueness
                        if (usedSlugs.has(m.move.name)) return false;

                        // 2. Check Learnset Availability in Valid Generations
                        // Does this pokemon learn this move in any allowed version group?
                        const learnsInAllowed = m.version_group_details.some(vgd =>
                            allowedGroups.has(vgd.version_group.name)
                        );
                        return learnsInAllowed;
                    })
                    .map(m => m.move.url);
            } else {
                // CHAOS MODE
                poolUrls = await getAllChaosMoves() || [];
            }

            if (poolUrls.length === 0) return [];

            // Pick random URLs
            const picks = [];
            // Pick MORE than needed to account for filters (Shadow/Gen/Unique)
            // Note: In Legal Mode, we already filtered by Learnset, so we only need to worry about
            // filters we can't check locally (like ID > 10000 or Shadow moves if they slipped in).
            // But utilized logic is robust.
            const targetPicks = count * 4;
            const MAX_ATTEMPTS = targetPicks * 5;
            let attempts = 0;

            if (CONFIG.legalMovesOnly) {
                // LEGAL MODE
                if (poolUrls.length <= targetPicks) {
                    picks.push(...poolUrls);
                } else {
                    const usedIndices = new Set();
                    while (picks.length < targetPicks && usedIndices.size < poolUrls.length) {
                        const r = randomIndex(poolUrls.length);
                        if (!usedIndices.has(r)) {
                            usedIndices.add(r);
                            picks.push(poolUrls[r]);
                        }
                    }
                }
            } else {
                // CHAOS MODE
                while (picks.length < targetPicks && attempts < MAX_ATTEMPTS) {
                    attempts++;
                    const url = poolUrls[randomIndex(poolUrls.length)];
                    picks.push(url);
                }
            }

            // Uniq picks locally
            const uniquePicks = [...new Set(picks)];

            // BLACKLIST for non-mainline / shadow moves
            const shadowMoves = new Set([
                'shadow-rush', 'shadow-blitz', 'shadow-bolt', 'shadow-break',
                'shadow-chill', 'shadow-end', 'shadow-fire', 'shadow-half',
                'shadow-hold', 'shadow-mist', 'shadow-panic', 'shadow-rave',
                'shadow-sky', 'shadow-storm', 'shadow-wave', 'shadow-down'
            ]);

            // Fetch & Filter
            const details = [];
            for (const url of uniquePicks) {
                if (details.length >= count) break; // DONE

                try {
                    const res = await fetch(url);
                    const d = await res.json();

                    // 1. GLOBAL UNIQUENESS CHECK
                    if (usedSlugs.has(d.name)) continue;

                    // 2. SPECIAL ID CHECK (Variants > 10000)
                    if (d.id > 10000) continue;

                    // 3. SHADOW/BLACKLIST CHECK
                    if (shadowMoves.has(d.name)) continue;

                    // 4. GENERATION CAP CHECK
                    const genParts = d.generation.url.split('/');
                    const genId = parseInt(genParts[genParts.length - 2]);
                    if (genId > CONFIG.maxGeneration) continue;

                    // Trova traduzione italiana o usa nome base
                    let name = d.names.find(n => n.language.name === 'it')?.name || d.name;

                    // Trova descrizione
                    const entry = d.flavor_text_entries.find(f => f.language.name === 'it')
                        || d.flavor_text_entries.find(f => f.language.name === 'en');
                    let desc = entry ? entry.flavor_text : "Descrizione non disponibile.";
                    desc = desc.replace(/[\n\f]/g, " ");

                    // --- NUOVO: Estrazione Categoria Danno ---
                    const dmgClassEn = d.damage_class ? d.damage_class.name : "status";
                    let dmgClassIt = "Stato";
                    if (dmgClassEn === "physical") dmgClassIt = "Fisico";
                    if (dmgClassEn === "special") dmgClassIt = "Speciale";

                    details.push({
                        name: name,
                        desc: desc,
                        accuracy: d.accuracy || "-",
                        power: d.power || "-",
                        type: d.type.name,
                        id: d.id,
                        originalName: d.name,
                        damageClass: dmgClassIt,      // Testo in italiano da mostrare
                        damageClassEn: dmgClassEn     // Testo in inglese utile per assegnare i colori
                    });
                } catch (e) {
                    console.error("Error fetching move", url, e);
                }
            }
            return details;
        }

