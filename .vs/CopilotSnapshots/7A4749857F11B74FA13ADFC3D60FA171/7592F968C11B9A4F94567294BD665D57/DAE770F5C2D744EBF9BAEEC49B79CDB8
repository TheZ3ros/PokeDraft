        function generateEvSpread() {
            const minTotal = CONFIG.minTotalEVs >= 0 ? CONFIG.minTotalEVs : 510;
            const maxTotal = CONFIG.maxTotalEVs >= minTotal ? CONFIG.maxTotalEVs : 510;

            // Random target total
            const range = maxTotal - minTotal + 1;
            let targetTotal = minTotal + randomIndex(range);

            // Stats keys
            const keys = ['hp', 'atk', 'def', 'spa', 'spd', 'spe'];
            const stats = { hp: 0, atk: 0, def: 0, spa: 0, spd: 0, spe: 0 };

            // Loop until we run out of points
            let currentTotal = 0;
            let safetyCounter = 0;
            const SAFETY_LIMIT = 5000;

            while (currentTotal < targetTotal && safetyCounter < SAFETY_LIMIT) {
                safetyCounter++;

                // Pick random stat
                const key = keys[randomIndex(keys.length)];

                // If stat is already full, skip
                if (stats[key] >= 252) continue;

                // Determine how many points we WANT to add (default 4, or remainder)
                const remainingGlobal = targetTotal - currentTotal;
                const chunk = remainingGlobal < 4 ? remainingGlobal : 4;

                // Determine how many points we CAN add to this stat (cap 252)
                const spaceInStat = 252 - stats[key];

                // Actual amount to add
                const amountToAdd = chunk < spaceInStat ? chunk : spaceInStat;

                if (amountToAdd > 0) {
                    stats[key] += amountToAdd;
                    currentTotal += amountToAdd;
                }
            }

            return stats;
        }

