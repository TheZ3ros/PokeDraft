            function safeSerialize(v) {
                try {
                    if (typeof v === 'string') return v;
                    return JSON.stringify(v);
                } catch (e) {
                    return String(v);
                }
            }

            function appendDebug(msg, level = 'log') {
                if (!debugContentEl) return;
                const line = document.createElement('div');
                line.textContent = `[${new Date().toLocaleTimeString()}] ${msg}`;
                line.style.padding = '2px 0';
                if (level === 'error') line.style.color = '#ff8b8b';
                else if (level === 'warn') line.style.color = '#ffd78a';
                else line.style.color = '#d1d5db';
                debugContentEl.appendChild(line);
                debugContentEl.scrollTop = debugContentEl.scrollHeight;
            }

            // Override console methods to also print to debug panel
            ['log', 'info', 'warn', 'error'].forEach(fn => {
                const orig = console[fn].bind(console);
                console[fn] = function(...args) {
                    try {
                        const text = args.map(a => safeSerialize(a)).join(' ');
                        appendDebug(text, fn === 'error' ? 'error' : (fn === 'warn' ? 'warn' : 'log'));
                    } catch (e) {
                        // ignore
                    }
                    orig(...args);
                };
