            updateTeamDisplay();

            currentPokeIndex++;
            showEvOptions();
        }

        /* -------------------------------------------------------------
           LOGICA SELEZIONE STRUMENTI (ITEMS)
           ------------------------------------------------------------- */
        let itemOptions = [];

        async function startItemSelection(resume = false) {
            gamePhase = 'ITEMS';

            // SKIP IF GEN 1 (No held items in Gen 1)
            if (CONFIG.maxGeneration === 1) {
                console.log("Gen 1 detected, skipping Item Phase.");
                gamePhase = 'COMPLETED';
                itemOptions = [];
                saveSession();
                finishGame();
                return;
            }

            if (resume && itemOptions.length > 0) {
                const currentPokemon = team[currentPokeIndex];
                document.querySelector('.title h1').textContent = `Scegli Strumento per ${currentPokemon.name}`;
                renderItemOptions(itemOptions);
                return;
            }

            if (!resume) {
                currentPokeIndex = 0;
            } else {
                // Resume logic
                let foundIndex = -1;
                for (let i = 0; i < team.length; i++) {
                    if (!team[i].item) {
                        foundIndex = i;
                        break;
                    }
                }
                if (foundIndex !== -1) currentPokeIndex = foundIndex;
                else {
                    finishGame();
                    return;
                }
            }

            showItemOptions();
        }

        async function showItemOptions() {
            // Check completion
            if (currentPokeIndex >= team.length) {
                gamePhase = 'COMPLETED';
                itemOptions = [];
                saveSession();
                finishGame();
                return;
            }

            const currentPokemon = team[currentPokeIndex];
            document.querySelector('.title h1').textContent = `Scegli Strumento per ${currentPokemon.name}`;
            document.querySelector('.reset-btn').style.display = 'block';

            // Filter items by Generation
            const validItems = ITEMS_DB.filter(i => i.minGen <= CONFIG.maxGeneration);

            // Generate 3 random items
            const options = [];

            // If few items are available (e.g. Gen 2 has few), handle gracefully
            // But we allow duplicates across pokemon, just not in the same set of 3

            let attempts = 0;
            while (options.length < 3 && attempts < 100) {
                const rand = validItems[randomIndex(validItems.length)];
                if (!options.some(o => o.name === rand.name)) {
                    options.push({ ...rand }); // Clone
                }
                attempts++;
            }

            // Fetch Images
            // API_BASE/api/v2/item/{slug}
            grid.innerHTML = '<div class="loading">Caricamento strumenti...</div>';

            for (let opt of options) {
                try {
                    const res = await fetch(`${API_BASE}/api/v2/item/${opt.slug}`);
                    const data = await res.json();
                    if (data.sprites && data.sprites.default) {
                        opt.sprite = data.sprites.default;
                    }
                } catch (e) {
                    console.error("Error fetching item sprite:", e);
                    // Fallback sprite? or just no sprite
                }
            }

            itemOptions = options;
            saveSession();

            renderItemOptions(options);
            updateTeamDisplay();
        }

        function renderItemOptions(items) {
            grid.innerHTML = '';

            items.forEach(item => {
                const card = document.createElement('div');
                card.className = 'item-card';
                card.onclick = () => selectItem(item);

                card.innerHTML = `
                        <div class="item-badge">${item.type}</div>
                        ${item.sprite ? `<img src="${item.sprite}" style="width:64px; height:64px; image-rendering:pixelated; margin-bottom:10px;">` : ''}
                        <div class="item-name">${item.name}</div>
                        <div class="item-desc">${item.desc}</div>
                    `;

                grid.appendChild(card);
            });
        }

        function selectItem(item) {
            if (document.body.dataset.processing === "true") return;

            const currentPokemon = team[currentPokeIndex];
            currentPokemon.item = item;

            updateTeamDisplay();

            currentPokeIndex++;
            showItemOptions();
        }

        /* -------------------------------------------------------------
           LOGICA EFFICACIA TIPI
           ------------------------------------------------------------- */
        // Dizionario per tradurre i nomi dei tipi in italiano
        const TYPE_TRANSLATIONS = {
            normal: "Normale", fighting: "Lotta", flying: "Volante", poison: "Veleno",
            ground: "Terra", rock: "Roccia", bug: "Coleottero", ghost: "Spettro",
            steel: "Acciaio", fire: "Fuoco", water: "Acqua", grass: "Erba",
            electric: "Elettro", psychic: "Psico", ice: "Ghiaccio", dragon: "Drago",
            dark: "Buio", fairy: "Folletto"
        };

        // Cache per non riscaricare gli stessi dati dei tipi più volte
        const TYPE_CACHE = {};

        async function calculateTypeEffectiveness(pokemonTypes) {
            const allTypes = Object.keys(TYPE_TRANSLATIONS);
            const multipliers = {};

            // Inizializziamo tutti i moltiplicatori a 1 (danno normale)
            allTypes.forEach(t => multipliers[t] = 1);

            for (const pt of pokemonTypes) {
                // Se non abbiamo ancora i dati di questo tipo, li scarichiamo
                if (!TYPE_CACHE[pt]) {
                    const res = await fetch(`https://pokeapi.co/api/v2/type/${pt}`);
                    TYPE_CACHE[pt] = await res.json();
                }
                const relations = TYPE_CACHE[pt].damage_relations;

                // Aggiorniamo i moltiplicatori in base alle relazioni di danno
                relations.double_damage_from.forEach(t => multipliers[t.name] *= 2);
                relations.half_damage_from.forEach(t => multipliers[t.name] *= 0.5);
                relations.no_damage_from.forEach(t => multipliers[t.name] *= 0);
            }

            // Categorizziamo i risultati
            const categories = { x4: [], x2: [], x0_5: [], x0_25: [], x0: [] };

            for (const [type, mult] of Object.entries(multipliers)) {
                if (mult === 4) categories.x4.push(type);
                else if (mult === 2) categories.x2.push(type);
                else if (mult === 0.5) categories.x0_5.push(type);
                else if (mult === 0.25) categories.x0_25.push(type);
                else if (mult === 0) categories.x0.push(type);
            }

            return categories;
        }

        /* -------------------------------------------------------------
           MODALE STATISTICHE (TASTO DESTRO)
           ------------------------------------------------------------- */
        async function openStatsModal(pokemon) {
            const modal = document.getElementById('statsModal');
            const content = document.getElementById('statsModalContent');

            const maxStat = 255;

            // Funzione per generare una singola barra colorata
            const renderBar = (label, val, color) => {
                const pct = Math.min(100, (val / maxStat) * 100);
                return `
                    <div class="stat-row-modal">
                        <div class="stat-label-modal">${label}</div>
                        <div class="stat-bar-bg-modal">
                            <div class="stat-bar-fill-modal" style="width: ${pct}%; background: ${color};"></div>
                        </div>
                        <div class="stat-val-modal">${val}</div>
                    </div>`;
            };

            // --- NUOVO: Creiamo le opzioni del menù a tendina per le abilità ---
            let abilityOptionsHtml = '';
            if (pokemon.abilities && pokemon.abilities.length > 0) {
                abilityOptionsHtml = pokemon.abilities.map((ab, idx) => {
                    return `<option value="${idx}" ${idx === pokemon.currentAbilityIndex ? 'selected' : ''}>${ab.name}</option>`;
                }).join('');
            } else {
                abilityOptionsHtml = `<option value="0">-</option>`;
            }

            // HTML interno della finestra (Struttura base + Abilità + Statistiche)
            content.innerHTML = `
                    <div class="modal-header-stats">
                        <img src="${pokemon.sprite}" alt="${pokemon.name}">
                        <h3>${pokemon.name}</h3>
                        <div class="pokemon-types" style="margin-top:5px;">
                            ${pokemon.types.map(t => `<span class="type-badge" style="background: var(--type-${t}, #aaa); padding: 4px 8px;">${TYPE_TRANSLATIONS[t] ? TYPE_TRANSLATIONS[t].toUpperCase() : t.toUpperCase()}</span>`).join('')}
                        </div>
                    </div>

                    <div style="margin-bottom: 15px; background: #f8fafc; padding: 10px; border-radius: 8px; border: 1px solid #e2e8f0;">
                        <label style="font-weight: bold; font-size: 0.85em; color: #4a5568; display: block; margin-bottom: 5px;">ABILITÀ:</label>
                        <select id="modalAbilitySelect" style="width: 100%; padding: 8px; border-radius: 6px; border: 1px solid #cbd5e0; margin-bottom: 8px; font-weight: bold; color: #2d3748; cursor: pointer;">
                            ${abilityOptionsHtml}
                        </select>
                        <div id="modalAbilityDesc" style="font-size: 0.85em; color: #718096; font-style: italic; min-height: 40px; background: #fff; padding: 8px; border-radius: 4px; border: 1px dashed #cbd5e0;">
                            Caricamento descrizione...
                        </div>
                    </div>

                    <div style="padding: 10px 0;">
                        ${renderBar('PS', pokemon.individualStats.hp, '#48bb78')}
                        ${renderBar('Atk', pokemon.individualStats.atk, '#f56565')}
                        ${renderBar('Dif', pokemon.individualStats.def, '#4299e1')}
                        ${renderBar('SpA', pokemon.individualStats.spa, '#9f7aea')}
                        ${renderBar('SpD', pokemon.individualStats.spd, '#ed64a6')}
                        ${renderBar('Vel', pokemon.individualStats.spe, '#ed8936')}
                    </div>
                    <div style="text-align: right; margin-top: 5px; margin-bottom: 15px; font-weight: 900; font-size: 1.1em; color: #2c3e50;">
                        BST: ${pokemon.bst}
                    </div>

                    <div id="modal-type-effectiveness">
                        <div style="text-align:center; color:#718096; font-size:0.9em;">Calcolo debolezze in corso...</div>
                    </div>
                `;

            modal.classList.add('active');

            // --- NUOVO: Gestione del caricamento descrizione abilità ---
            const abilitySelect = document.getElementById('modalAbilitySelect');
            const abilityDesc = document.getElementById('modalAbilityDesc');

            const loadAbilityDesc = async (index) => {
                abilityDesc.innerHTML = "Caricamento descrizione...";
                const ab = pokemon.abilities[index];

                if (!ab || ab.slug === '-') {
                    abilityDesc.innerHTML = "Nessuna abilità disponibile.";
                    return;
                }

                try {
                    // Ottimizzazione: se abbiamo già scaricato questa descrizione, usiamo quella salvata
                    if (ab.desc) {
                        abilityDesc.innerHTML = ab.desc;
                        return;
                    }

                    // Altrimenti interroghiamo le API
                    const res = await fetch(`https://pokeapi.co/api/v2/ability/${ab.slug}`);
                    const data = await res.json();

                    // Cerchiamo il testo in italiano, altrimenti fallback su inglese
                    const entry = data.flavor_text_entries.find(f => f.language.name === 'it') || data.flavor_text_entries.find(f => f.language.name === 'en');

                    // Puliamo il testo dai ritorni a capo strani delle API
                    const descText = entry ? entry.flavor_text.replace(/[\n\f]/g, " ") : "Descrizione non disponibile.";

                    ab.desc = descText; // Salviamo la descrizione nell'oggetto Pokémon per non riscaricarla
                    abilityDesc.innerHTML = descText;
                } catch (e) {
                    abilityDesc.innerHTML = "Impossibile caricare la descrizione.";
                }
            };

            // Carichiamo la descrizione dell'abilità attualmente selezionata all'apertura del modale
            loadAbilityDesc(pokemon.currentAbilityIndex);

            // Quando l'utente seleziona una nuova abilità dal menù a tendina...
            abilitySelect.onchange = (e) => {
                const newIndex = parseInt(e.target.value);
                pokemon.currentAbilityIndex = newIndex; // Aggiorna il Pokémon
                saveSession(); // Salva nel LocalStorage

                // Aggiorna le grafiche del team in background in modo che restino sincronizzate!
                if (typeof updateTeamDisplay === 'function') updateTeamDisplay();
                if (gamePhase === 'POKEMON' && typeof renderGrid === 'function') renderGrid();

                // Carica la nuova descrizione
                loadAbilityDesc(newIndex);
            };

            // --- Calcolo debolezze ---
            try {
                const eff = await calculateTypeEffectiveness(pokemon.types);
                let effHtml = '';

                const buildBox = (title, types, bgColor, textColor, borderColor) => {
                    if (!types || types.length === 0) return '';

                    const badges = types.map(t => `<span class="type-badge" style="background: var(--type-${t}, #aaa); padding: 3px 6px; font-size: 0.8em; margin-bottom: 4px;">${TYPE_TRANSLATIONS[t] ? TYPE_TRANSLATIONS[t].toUpperCase() : t.toUpperCase()}</span>`).join('');

                    return `
                            <div style="background: ${bgColor}; border: 1px solid ${borderColor}; border-radius: 8px; padding: 10px; margin-bottom: 10px;">
                                <div style="color: ${textColor}; font-weight: bold; font-size: 0.85em; margin-bottom: 8px; letter-spacing: 0.5px;">${title}</div>
                                <div style="display: flex; flex-wrap: wrap; gap: 5px;">${badges}</div>
                            </div>
                        `;
                };

                effHtml += buildBox('SUPER DEBOLE (X4)', eff.x4, '#fff5f5', '#c53030', '#feb2b2');
                effHtml += buildBox('DEBOLE (X2)', eff.x2, '#fffff0', '#b7791f', '#f6e05e');
                effHtml += buildBox('RESISTENTE (X½)', eff.x0_5, '#f0fff4', '#2f855a', '#9ae6b4');
                effHtml += buildBox('SUPER RESISTENTE (X¼)', eff.x0_25, '#e6fffa', '#285e61', '#81e6d9');
                effHtml += buildBox('IMMUNE (X0)', eff.x0, '#ebf8ff', '#2b6cb0', '#90cdf4');

                document.getElementById('modal-type-effectiveness').innerHTML = effHtml;
            } catch (error) {
                console.error(error);
                document.getElementById('modal-type-effectiveness').innerHTML = '<div style="color:red; text-align:center; font-size:0.9em;">Errore nel calcolo delle debolezze.</div>';
            }
        }

        function closeStatsModal() {
            document.getElementById('statsModal').classList.remove('active');
        }

        // Avvio
        window.addEventListener('DOMContentLoaded', initialize);
    </script>
